#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

from tools.setup_wizard import main as onboard_main


def main() -> None:
    parser = argparse.ArgumentParser(prog="bpc", description="BioPaperClaw CLI")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("onboard", help="Run interactive onboarding wizard")

    if len(sys.argv) > 1 and sys.argv[1] == "onboard":
        # Pass through any extra args after subcommand to wizard
        sys.argv = ["bpc-onboard", *sys.argv[2:]]
        onboard_main()
        return

    args = parser.parse_args()
    if args.command is None:
        parser.print_help()


if __name__ == "__main__":
    main()
